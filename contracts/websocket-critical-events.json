{
  "version": 2,
  "events": {
    "host_sync": {
      "channel": "room-{roomId}",
      "fields": {
        "timestamp": "number",
        "url": "string",
        "roomId": "string",
        "state": "playing|paused",
        "videoId": "string",
        "sentAt": "number",
        "reason": "tick|play|pause|seek|load|resync|ended"
      }
    },
    "room_video_state": {
      "channel": "user-{userId}",
      "fields": {
        "roomId": "string",
        "sync": "RoomSyncData|null"
      }
    },
    "user_presence_updated": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "userName": "string",
        "presenceState": "active|away|offline",
        "timestamp": "string"
      }
    },
    "room_presence_status": {
      "channel": "user-{userId}",
      "fields": {
        "roomId": "string",
        "participants": "Array<{ userId: string, userName: string, presenceState: active|away|offline }>"
      }
    },
    "stream_mode_changed": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "mode": "none|url|screen|camera|file",
        "peerId": "string?",
        "reason": "stopped|disconnect|replaced|failed?"
      }
    },
    "stream_status": {
      "channel": "user-{userId}",
      "fields": {
        "roomId": "string",
        "currentStreamerId": "string?",
        "currentStreamMode": "string?",
        "currentStreamerPeerId": "string?"
      }
    },
    "webcam_join": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "userName": "string",
        "userImage": "string?",
        "videoEnabled": "boolean",
        "audioEnabled": "boolean"
      }
    },
    "webcam_leave": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string"
      }
    },
    "webcam_toggle": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "type": "audio|video",
        "enabled": "boolean"
      }
    },
    "webcam_state": {
      "channel": "user-{userId}",
      "fields": {
        "roomId": "string",
        "participants": "Array<{ userId: string, userName: string, userImage?: string, videoEnabled: boolean, audioEnabled: boolean }>"
      }
    },
    "cinema_avatar_update": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "userName": "string",
        "px": "number",
        "py": "number",
        "pz": "number",
        "ry": "number",
        "anim": "string",
        "avatarModel": "string?"
      }
    },
    "cinema_avatar_state": {
      "channel": "user-{userId}",
      "fields": {
        "roomId": "string",
        "avatars": "Array<CinemaAvatarData>"
      }
    },
    "cinema_animation": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "userName": "string",
        "animation": "string"
      }
    },
    "cinema_mood_changed": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "userName": "string",
        "color": "string",
        "brightness": "number",
        "timestamp": "string?"
      }
    },
    "cinema_room_theme_changed": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "userName": "string",
        "themeId": "imax|arthouse|grindhouse|noir",
        "timestamp": "string?"
      }
    },
    "face_mode_toggle": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "enabled": "boolean"
      }
    },
    "face_mode_state": {
      "channel": "user-{userId}",
      "fields": {
        "roomId": "string",
        "participants": "Array<{ userId: string, enabled: boolean }>"
      }
    },
    "video_reaction": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "userName": "string",
        "emoji": "string",
        "videoTimestamp": "number",
        "timestamp": "string",
        "reactionId": "string"
      }
    },
    "room_announcement": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "type": "string",
        "userName": "string",
        "message": "string",
        "timestamp": "string",
        "announcementId": "string",
        "metadata": "object?"
      }
    },
    "webcam_hub_change": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "newHubUserId": "string?",
        "timestamp": "string"
      }
    },
    "queue_updated": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "queue": "Array<{ id: string, videoUrl: string, videoTitle?: string, addedBy: { userId: string, userName: string }, addedAt: number }>"
      }
    },
    "queue_countdown": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "secondsRemaining": "number",
        "nextItem": "{ id: string, videoUrl: string, videoTitle?: string, addedBy: { userId: string, userName: string }, addedAt: number }"
      }
    },
    "queue_autoplay": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "item": "{ id: string, videoUrl: string, videoTitle?: string, addedBy: { userId: string, userName: string }, addedAt: number }"
      }
    },
    "role_changed": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "newRole": "string",
        "changedBy": "string"
      }
    },
    "user_muted": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "expiresAt": "string",
        "mutedBy": "string",
        "reason": "string?"
      }
    },
    "user_unmuted": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string"
      }
    },
    "message_deleted": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "messageId": "string",
        "deletedBy": "string"
      }
    },
    "movie_proposed": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "proposalId": "string",
        "movie": "{ id: string, tmdbId: string, title: string, posterPath: string?, releaseDate: string?, voteAverage: string? }",
        "proposer": "{ id: string, name: string, image: string? }",
        "expiresAt": "string"
      }
    },
    "movie_vote_update": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "proposalId": "string",
        "votes": "{ up: Array<{ id: string, name: string, image: string? }>, down: Array<{ id: string, name: string, image: string? }> }"
      }
    },
    "movie_approved": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "proposalId": "string",
        "movie": "{ id: string, tmdbId: string, title: string, posterPath: string?, releaseDate: string?, voteAverage: string? }",
        "approvedBy": "{ id: string, name: string, image: string? }"
      }
    },
    "movie_rejected": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "proposalId": "string",
        "reason": "host|timeout|majority_down"
      }
    },
    "lock_changed": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "lockState": "open|invite-only|locked",
        "changedBy": "string"
      }
    },
    "participant_banned": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "userName": "string",
        "banType": "session|timed|permanent",
        "reason": "string?",
        "bannedBy": "string"
      }
    },
    "participant_unbanned": {
      "channel": "room-{roomId}",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "unbannedBy": "string"
      }
    },
    "you_banned": {
      "channel": "user-{userId}",
      "fields": {
        "roomId": "string",
        "roomName": "string",
        "banType": "session|timed|permanent",
        "reason": "string?",
        "expiresAt": "string?"
      }
    },
    "stream_mode_changed": {
      "channel": "room-{roomId}",
      "description": "Broadcast when streaming state changes (FIFO: first to stream gets exclusive access)",
      "fields": {
        "roomId": "string",
        "userId": "string",
        "mode": "none|screen|camera|file|url",
        "reason": "string?"
      }
    },
    "stream_status": {
      "channel": "user-{userId}",
      "description": "Response to get_stream_status request - returns current streaming state for late joiners",
      "fields": {
        "roomId": "string",
        "currentStreamerId": "string?",
        "currentStreamMode": "string?"
      }
    }
  }
}
